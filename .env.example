NODE_ENV=development
PORT=3000
APP_NAME=stoury-api
CLIENT_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
ENABLE_HTTPS_UPGRADE_CSP=false

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=stoury_api_dev
DB_USER=postgres
DB_PASSWORD=postgres

DB_NAME_TEST=stoury_api_test
DB_USER_TEST=postgres
DB_PASSWORD_TEST=postgres

DB_NAME_PROD=stoury_api
DB_USER_PROD=postgres
DB_PASSWORD_PROD=change_me

DATABASE_URL=
DATABASE_URL_TEST=
DATABASE_URL_PROD=

DB_LOGGING=false
DB_SSL=false
